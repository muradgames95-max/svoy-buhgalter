datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id             String    @id @default(cuid())
  name           String?
  email          String    @unique
  emailVerified  DateTime?
  image          String?
  password       String?
  plan           String    @default("free")
  planExpiresAt  DateTime?
  planPeriod     String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  accounts       Account[]
  sessions       Session[]
  userData       UserData?
}

model UserData {
  id             String   @id @default(cuid())
  userId         String   @unique
  incomes        String   @default("[]")
  expenses       String   @default("[]")
  clients        String   @default("[]")
  documents      String   @default("[]")
  profile        String   @default("{}")
  settings       String   @default("{}")
  chatHistory    String   @default("[]")
  chatMonthKey   String   @default("")
  chatMonthCount Int      @default(0)
  docMonthKey    String   @default("")
  docMonthCount  Int      @default(0)
  updatedAt      DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
